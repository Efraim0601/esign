<%
  icon_palette = [
    { bg: 'bg-red-100',    fg: 'text-red-700' },
    { bg: 'bg-blue-100',   fg: 'text-blue-700' },
    { bg: 'bg-amber-100',  fg: 'text-amber-700' },
    { bg: 'bg-emerald-100', fg: 'text-emerald-700' },
    { bg: 'bg-violet-100', fg: 'text-violet-700' },
    { bg: 'bg-sky-100',    fg: 'text-sky-700' }
  ]
  name_sort_aria    = selected_order == 'name' ? 'ascending'  : 'none'
  date_sort_aria    = selected_order == 'created_at' ? 'descending' : 'none'
%>
<div class="overflow-x-auto rounded-2xl border border-base-300">
  <table class="table table-zebra w-full">
    <thead class="bg-base-200 text-xs uppercase text-base-content/70">
      <tr>
        <th scope="col" class="w-10"></th>
        <th scope="col" aria-sort="<%= name_sort_aria %>">
          <form action="<%= templates_path %>" method="get" class="inline">
            <% request.query_parameters.except(:controller, :action, :order).each do |key, value| %>
              <input type="hidden" name="<%= key %>" value="<%= value %>">
            <% end %>
            <toggle-cookies data-value="name" data-key="dashboard_templates_order">
              <button type="submit" class="inline-flex items-center gap-1 hover:text-base-content focus:outline-none focus-visible:underline">
                <%= t('name') %>
                <%= svg_icon('chevron_down', class: "w-3 h-3 #{'opacity-100' if selected_order == 'name'} #{'opacity-30' unless selected_order == 'name'}") %>
              </button>
            </toggle-cookies>
          </form>
        </th>
        <th scope="col" class="hidden md:table-cell"><%= t('author') %></th>
        <th scope="col" aria-sort="<%= date_sort_aria %>">
          <form action="<%= templates_path %>" method="get" class="inline">
            <% request.query_parameters.except(:controller, :action, :order).each do |key, value| %>
              <input type="hidden" name="<%= key %>" value="<%= value %>">
            <% end %>
            <toggle-cookies data-value="created_at" data-key="dashboard_templates_order">
              <button type="submit" class="inline-flex items-center gap-1 hover:text-base-content focus:outline-none focus-visible:underline">
                <%= t('created_at') %>
                <%= svg_icon('chevron_down', class: "w-3 h-3 #{'opacity-100' if selected_order == 'created_at'} #{'opacity-30' unless selected_order == 'created_at'}") %>
              </button>
            </toggle-cookies>
          </form>
        </th>
        <th scope="col" class="hidden md:table-cell"><%= t('submissions') %></th>
        <th scope="col" class="text-right"><%= t('column_actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% templates.each_with_index do |template, idx| %>
        <% palette = icon_palette[idx % icon_palette.size] %>
        <tr class="hover cursor-pointer" onclick="if (event.target.closest('a, button, form, label')) return; window.location='<%= template_path(template) %>'">
          <td>
            <span class="w-8 h-8 rounded-md flex items-center justify-center <%= palette[:bg] %> <%= palette[:fg] %>">
              <%= svg_icon('file_text', class: 'w-4 h-4') %>
            </span>
          </td>
          <td>
            <%= link_to template_path(template), class: 'font-medium text-base-content hover:underline inline-flex items-start gap-1' do %>
              <% if template.template_accesses.present? || template.private? %>
                <%= svg_icon('lock', class: 'w-4 h-4 mt-0.5 flex-shrink-0') %>
              <% end %>
              <span class="break-all">
                <% template.name.split(/(_)/).each do |item| %><%= item %><wbr><% end %>
              </span>
            <% end %>
            <% if template.account_id != current_account.id %>
              <span class="badge badge-neutral badge-outline badge-sm text-[10px] uppercase ml-1"><%= t('shared') %></span>
            <% end %>
          </td>
          <td class="hidden md:table-cell text-sm text-base-content/70">
            <%= template.author.full_name.presence || template.author.email.to_s.sub(/\+\w+@/, '@') %>
          </td>
          <td class="text-sm text-base-content/70 whitespace-nowrap">
            <%= l(template.created_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) %>
          </td>
          <td class="hidden md:table-cell">
            <span class="badge badge-ghost"><%= template.submissions_count %></span>
          </td>
          <td>
            <div class="flex items-center justify-end gap-1">
              <% if can?(:update, template) && !template.archived_at? && template.account_id == current_account.id %>
                <span class="tooltip tooltip-left" data-tip="<%= t('move') %>">
                  <a href="<%= edit_template_folder_path(template.id) %>" data-turbo-frame="modal" class="btn btn-ghost btn-xs btn-square">
                    <%= svg_icon('folder_share', class: 'w-4 h-4') %>
                  </a>
                </span>
              <% end %>
              <% if template.archived_at? && can?(:update, template) %>
                <span class="tooltip tooltip-left" data-tip="<%= t('restore') %>">
                  <%= button_to template_restore_index_path(template), class: 'btn btn-ghost btn-xs btn-square' do %>
                    <%= svg_icon('rotate', class: 'w-4 h-4 enabled') %>
                    <%= svg_icon('loader', class: 'w-4 h-4 animate-spin disabled') %>
                  <% end %>
                </span>
              <% elsif can?(:update, template) %>
                <span class="tooltip tooltip-left" data-tip="<%= t('edit') %>">
                  <a href="<%= edit_template_path(template) %>" class="btn btn-ghost btn-xs btn-square">
                    <%= svg_icon('pencil', class: 'w-4 h-4') %>
                  </a>
                </span>
              <% end %>
              <% if can?(:create, template) %>
                <span class="tooltip tooltip-left" data-tip="<%= t('clone') %>">
                  <a href="<%= new_template_clone_path(template) %>" data-turbo-frame="modal" class="btn btn-ghost btn-xs btn-square">
                    <%= svg_icon('copy', class: 'w-4 h-4') %>
                  </a>
                </span>
              <% end %>
              <% if can?(:destroy, template) %>
                <span class="tooltip tooltip-left" data-tip="<%= template.archived_at? ? t('delete') : t('archive') %>">
                  <%= button_to template_path(template), data: template.archived_at? ? { turbo_confirm: t('template_deletion_is_irreversible_and_will_permanently_remove_all_associated_signed_documents_with_it_are_you_sure_') } : {}, params: { permanently: template.archived_at? }.compact_blank, method: :delete, class: 'btn btn-ghost btn-xs btn-square', aria_label: t('archive') do %>
                    <%= svg_icon(template.archived_at? ? 'trash' : 'archive', class: 'w-4 h-4 enabled') %>
                    <%= svg_icon('loader', class: 'w-4 h-4 animate-spin disabled') %>
                  <% end %>
                </span>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
