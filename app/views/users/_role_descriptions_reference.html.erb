<details class="mt-3 rounded-lg border border-base-300 bg-base-200/30 p-3 open:bg-base-200/50">
  <summary class="cursor-pointer text-sm font-medium text-base-content select-none flex items-center gap-2 list-none [&::-webkit-details-marker]:hidden">
    <%= svg_icon('info_circle', class: 'w-4 h-4 shrink-0 opacity-80') %>
    <span class="underline decoration-dotted decoration-base-content/30 underline-offset-2"><%= t('role_permissions_help_title') %></span>
  </summary>
  <div class="mt-3 space-y-3 text-sm text-base-content/85 border-t border-base-300 pt-3">
    <% User::ROLES.each do |role_key| %>
      <div>
        <p class="font-medium text-base-content"><%= t(role_key) %></p>
        <p class="mt-0.5 leading-snug"><%= t("role_description_#{role_key}") %></p>
      </div>
    <% end %>
  </div>
</details>
