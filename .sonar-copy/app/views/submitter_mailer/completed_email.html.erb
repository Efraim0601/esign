<% if @body.present? %>
  <%= render 'custom_content', content: @body, submitter: @submitter %>
<% else %>
  <% document_name = @submitter.submission.name || @submitter.submission.template.name %>
  <% signers = @submitter.submission.submitters.order(:completed_at).map { |e| e.name.presence || e.email.presence || e.phone }.uniq.join(', ') %>
  <p><%= t('hi_there') %>,</p>
  <p><%= I18n.t(:name_has_been_completed_by_submitters, name: document_name, submitters: signers) %></p>
  <p><%= t('signed_copy_attached') %></p>
  <p><%= link_to submission_url(@submitter.submission), submission_url(@submitter.submission) %></p>
  <p>
    <%= t('thanks') %>,<br><%= @current_account.name %>
  </p>
<% end %>
