<% if @body.present? %>
  <%= render 'custom_content', content: @body, submitter: @submitter, sig: @sig %>
<% else %>
  <% document_name = @submitter.submission.name || @submitter.submission.template.name %>
  <% preview_url = submissions_preview_url(@submitter.submission.slug, { sig: @sig, host: @custom_domain || ENV.fetch('EMAIL_HOST', Docuseal.default_url_options[:host]) }.compact) %>
  <p><%= t('hello_name', name: (@submitter.name.presence || @submitter.email)) %>,</p>
  <p><%= t('please_check_the_copy_of_your_name_in_the_email_attachments', name: document_name) %></p>
  <p><%= t('alternatively_you_can_review_and_download_your_copy_using_the_link_below') %></p>
  <p style="margin:24px 0;">
    <a href="<%= preview_url %>" style="background:#1d4ed8;color:#ffffff;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:600;display:inline-block;">
      <%= document_name %>
    </a>
  </p>
  <p>
    <%= t('thanks') %>,<br><%= @current_account.name %>
  </p>
<% end %>
