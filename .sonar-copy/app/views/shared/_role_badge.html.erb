<% classes = case role
  when 'admin' then 'bg-red-100 text-red-800'
  when 'editor' then 'bg-blue-100 text-blue-800'
  when 'member' then 'bg-green-100 text-green-800'
  when 'agent' then 'bg-yellow-100 text-yellow-800'
  when 'viewer' then 'bg-gray-100 text-gray-800'
  else 'bg-gray-100 text-gray-800'
end %>
<span class="badge badge-outline <%= classes %> whitespace-nowrap">
  <%= t("roles.#{role}", default: role.capitalize) %>
</span>