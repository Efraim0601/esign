<submitters-autocomplete data-field="name">
  <linked-input data-target-id="<%= "phone_name_#{item['linked_to_uuid']}" if item['linked_to_uuid'].present? %>">
    <input type="text" name="submission[1][submitters][][name]" autocomplete="off" class="base-input !h-10 <%= 'mt-1.5' if local_assigns[:with_top_margin] %> w-full" placeholder="<%= "#{t('name')} (#{t('optional')})" %>" value="<%= (params[:selfsign] && index.zero?) || item['is_requester'] ? current_user.full_name : '' %>" dir="auto" id="phone_name_<%= item['uuid'] %>">
  </linked-input>
</submitters-autocomplete>
